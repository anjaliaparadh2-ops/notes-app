# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/notes_app

# Port the backend server runs on
PORT=5000

# Simple admin upload password (checked on the /api/upload route)
ADMIN_SECRET=changeme123

# Max upload size in bytes (default here = 1GB)
MAX_FILE_SIZE=1073741824

# Base URL used to build public file links (change in production, e.g. https://api.yourdomain.com)
BASE_URL=http://localhost:5000
